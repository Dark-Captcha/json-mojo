def _garbage() -> List[List[UInt8]]:
    var out = List[List[UInt8]]()
    _garbage_0(out)
    _garbage_1(out)
    _garbage_2(out)
    _garbage_3(out)
    _garbage_4(out)
    _garbage_5(out)
    _garbage_6(out)
    _garbage_7(out)
    _garbage_8(out)
    return out^


def main() raises:
    var fails = 0
    var valid = _valid()
    for i in range(len(valid)):
        try:
            var got = json.dumps(json.loads(valid[i]))
            if got != valid[i]:
                print("RT MISMATCH in=", valid[i], " out=", got)
                fails += 1
        except e:
            print("RT RAISED on valid:", valid[i], e)
            fails += 1
    var garbage = _garbage()
    for i in range(len(garbage)):
        try:
            _ = json.loads_bytes(garbage[i].copy())
        except:
            pass
    print(
        "fuzz: roundtrip=",
        len(valid),
        " nocrash=",
        len(garbage),
        " fails=",
        fails,
    )
    if fails != 0:
        raise Error("fuzz failures: " + String(fails))
    print("FUZZ OK")
