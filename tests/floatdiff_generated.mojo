def _wantbits() -> List[UInt64]:
    var out = List[UInt64]()
    _wantbits_0(out)
    _wantbits_1(out)
    _wantbits_2(out)
    _wantbits_3(out)
    _wantbits_4(out)
    _wantbits_5(out)
    _wantbits_6(out)
    _wantbits_7(out)
    _wantbits_8(out)
    _wantbits_9(out)
    _wantbits_10(out)
    _wantbits_11(out)
    _wantbits_12(out)
    _wantbits_13(out)
    _wantbits_14(out)
