def _oks() -> List[Bool]:
    var out = List[Bool]()
    _oks_0(out)
    _oks_1(out)
    _oks_2(out)
    _oks_3(out)
    _oks_4(out)
    _oks_5(out)
    _oks_6(out)
    _oks_7(out)
    _oks_8(out)
    _oks_9(out)
    _oks_10(out)
    return out^


def main() raises:
    var cs = _cases()
    var oks = _oks()
    var fails = 0
    for i in range(len(cs)):
        var got_ok = True
        try:
            _ = json.loads_bytes(cs[i].copy())
        except:
            got_ok = False
        if got_ok != oks[i]:
            print("UTF8 DIVERGE i=", i, " got_ok=", got_ok, " want=", oks[i])
            fails += 1
    print("utf8diff: cases=", len(cs), " fails=", fails)
    if fails != 0:
        raise Error("utf8 diff failures: " + String(fails))
    print("UTF8DIFF OK")
